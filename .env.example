# Telegram Bot
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-numeric-chat-id

# Ollama (local LLM - auto-detected for WSL, set manually if needed)
OLLAMA_URL=
DEFAULT_MODEL=qwen2.5:7b
CODE_MODEL=deepseek-coder:6.7b

# Cloud LLM cascade (Groq -> Gemini -> Local Ollama)
# Get free keys at: https://console.groq.com and https://aistudio.google.com/apikey
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Agent settings
WORKSPACE=/mnt/c/Users/yourname/ai-agent
PERMISSION_TIMEOUT=300

# Optional: comma-separated allowed paths for file operations
# ALLOWED_PATHS=/mnt/c/Users/yourname,/mnt/d
